# Runtime connection string. For Neon, use the pooled URL here.
DATABASE_URL="postgresql://hanlingo:hanlingo@localhost:5432/hanlingo?schema=public"
# Prisma CLI / migrations. For Neon, use the non-pooled direct URL here.
DIRECT_URL="postgresql://hanlingo:hanlingo@localhost:5432/hanlingo?schema=public"
SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
SESSION_COOKIE_SECURE="false"
HANLINGO_DEV_FILE_STORE="false"
